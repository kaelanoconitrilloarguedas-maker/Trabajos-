/* cara frontal */
.front {
    background: hwb(0 0% 100% / 0.811); /* Fondo blanco semitransparente */
    color: #fff; /* Texto blanco */
    border-radius: 10px; /* Bordes redondeados */
    box-shadow: 0 0 20px rgba(139, 0, 0, 0.6); /* Sombra roja */
    transition: transform 0.8s ease; /* Suaviza el giro */
}

/* cara trasera */
.back {
    background: hwb(0 0% 100% / 0.811); /* Fondo blanco semitransparente */
    color: #fff; /* Texto blanco */
    transform: rotateY(180deg); /* Girada 180° */
    border-radius: 10px; /* Bordes redondeados */
    box-shadow: 0 0 20px rgba(139, 0, 0, 0.6); /* Sombra roja */
    transition: transform 0.8s ease; /* Suaviza el giro */
}

/* efecto hover para girar tarjeta */
.card:hover .front {
    transform: rotateY(180deg); /* Gira la cara frontal */
}
.card:hover .back {
    transform: rotateY(360deg); /* Gira la cara trasera hacia el frente */
}

