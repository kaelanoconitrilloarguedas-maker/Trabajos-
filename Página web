    max-width: 300px; /* Máximo ancho */
    height: 400px; /* Alto fijo */
    perspective: 1000px; /* Profundidad para efecto 3D */
    margin: auto; /* Centra horizontalmente */
    cursor: pointer; /* Cambia el cursor al pasar sobre la tarjeta */
    margin-bottom: 20%; /* Separación inferior grande */
}

/* caras de la tarjeta */
.face {
    width: 100%; /* Ocupa todo el ancho */
    height: 100%; /* Ocupa todo el alto */
    position: absolute; /* Posicionamiento superpuesto */
    backface-visibility: hidden; /* Oculta la cara trasera al girar */
    transition: transform 0.8s ease; /* Transición suave al rotar */
    display: flex; /* Centra el contenido */
    flex-direction: column; /* Organiza contenido en columna */
    justify-content: center; /* Centra verticalmente */
    align-items: center; /* Centra horizontalmente */
